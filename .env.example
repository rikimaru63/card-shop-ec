# Supabase
NEXT_PUBLIC_SUPABASE_URL="your-supabase-project-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Admin Dashboard Auth
ADMIN_USER="admin"
ADMIN_PASSWORD="your-secure-password"

# Resend (Email)
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="noreply@yourdomain.com"
EMAIL_FROM_NAME="Card Shop"

# Wise Bank Account Info (for invoice emails)
WISE_ACCOUNT_HOLDER="Your Company Name"
WISE_IBAN="BE12 3456 7890 1234"
WISE_BIC="TRWIBEB1XXX"

# Wise API (optional, for future automation)
WISE_API_KEY="your-wise-api-key"
WISE_PROFILE_ID="your-wise-profile-id"
WISE_WEBHOOK_SECRET="your-wise-webhook-secret"

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Algolia (Search)
NEXT_PUBLIC_ALGOLIA_APP_ID="your-algolia-app-id"
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY="your-search-key"
ALGOLIA_ADMIN_KEY="your-admin-key"

# Google Analytics
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Stripe (Alternative Payment)
STRIPE_SECRET_KEY="sk_test_xxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxx"

# Site Branding
NEXT_PUBLIC_SITE_NAME="Card Shop"
NEXT_PUBLIC_SITE_DESCRIPTION="Your premier destination for trading cards"
NEXT_PUBLIC_BASE_URL="https://your-domain.com"
NEXT_PUBLIC_SUPPORT_EMAIL="support@your-domain.com"
NEXT_PUBLIC_SUPPORT_PHONE=""
NEXT_PUBLIC_ADDRESS=""

# Social Media
NEXT_PUBLIC_INSTAGRAM_URL=""
NEXT_PUBLIC_TWITTER_URL=""
NEXT_PUBLIC_TWITTER_HANDLE=""
NEXT_PUBLIC_FACEBOOK_URL=""
NEXT_PUBLIC_YOUTUBE_URL=""

# Tracking (Meta Pixel)
# REGION別のPixel ID（優先）。US版とEU版で別のピクセルを使いたい場合はこちらを設定。
NEXT_PUBLIC_META_PIXEL_ID_US=""
NEXT_PUBLIC_META_PIXEL_ID_EU=""
# 共通Pixel ID（後方互換）。REGION別が未設定のときのフォールバック。
NEXT_PUBLIC_META_PIXEL_ID=""

# Business Logic
NEXT_PUBLIC_SHIPPING_COST="4500"
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD="50000"

# Region (US or EU)
NEXT_PUBLIC_REGION="US"

# Cron Job Secret（必ず設定すること。未設定だと /api/cron/* が認証なしでアクセス可能になる）
CRON_SECRET=""

# Pikachu Promo Modal (初回5万円以上購入時のお祝いモーダル)
# "true" で有効化。未設定or"false"で無効（現状: 無効）
NEXT_PUBLIC_PIKACHU_PROMO_ENABLED=""

# Auto-release of expired reservations (24h unpaid orders)
# "true" で自動解放Cron有効化。未設定or"false"で手動解放のみ運用（現状: 無効）
AUTO_RELEASE_RESERVATIONS_ENABLED=""
